# QEIB private benchmark material and local run outputs
research/qeib/private/
# Ignore the entire local run-output tree, including nested per-run directories
# (e.g. results/ollama-<stamp>/runs.jsonl). The earlier results/*.ext patterns
# only matched direct children and let nested raw logs slip into git status.
research/qeib/results/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Local environment
.env
.env.*
.DS_Store
